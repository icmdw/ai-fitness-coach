# 环境变量配置模板

# ====================
# 服务器配置
# ====================
NODE_ENV=production
PORT=3000

# ====================
# 数据库配置
# ====================
# SQLite 数据库文件路径
DATABASE_URL=file:/app/data/fitness.db

# 如果使用 PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/fitness_db

# ====================
# JWT 认证配置
# ====================
# ⚠️ 生产环境务必修改为强随机字符串
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# ====================
# AI 配置 (Higress Gateway)
# ====================
HIGRESS_GATEWAY_URL=http://aigw-local.hiclaw.io:8080/v1
HIGRESS_API_KEY=your-api-key-here

# ====================
# 前端配置
# ====================
# API 代理地址（Docker 内部使用）
VITE_API_URL=http://localhost/api

# ====================
# 日志配置
# ====================
LOG_LEVEL=info
LOG_FILE=/app/logs/app.log

# ====================
# 备份配置
# ====================
# 数据备份保留天数
BACKUP_RETENTION_DAYS=7
