# 服务器配置
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# JWT 配置
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# 数据库配置
DATABASE_URL="file:./prisma/dev.db"

# CORS 配置
CORS_ORIGIN=http://localhost:5173

# AI Gateway 配置 (可选)
HIGRESS_API_KEY=your-api-key
HIGRESS_API_URL=https://dashscope.aliyuncs.com/api/v1
